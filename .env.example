# Copy to .env for local runs. Do not commit .env.

# Cleaned source folder containing platform/part breakdown data.
MSD_SOURCE_DIR=./data/Omnify_All_Parts_Cleaned

# Local SQLite index path. This file is ignored by Git.
MSD_DB_PATH=./omnify_search.sqlite

# Static frontend directory.
MSD_STATIC_DIR=./omnify_search_static

# Local server binding. Keep 127.0.0.1 for local-only use.
MSD_BIND_HOST=127.0.0.1
MSD_PORT=8765
MSD_OPEN_BROWSER=false

# Optional HTTP Basic Auth for any shared or remotely reachable Python deployment.
# Leave blank for local-only use.
MSD_BASIC_AUTH_USER=
MSD_BASIC_AUTH_PASSWORD=

# Future Supabase frontend values. These are safe only when Row Level Security
# is enabled and policies are correctly scoped.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Local import-only secret. Use only from scripts/import_to_supabase.py.
# Never place this in frontend code.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=manufacturing-documents
